# ─── JWT (ต้องเหมือนกันทุก service) ───────────────────────────
JWT_SECRET=engse207-shared-secret-set2
JWT_EXPIRES_IN=1h

# ─── auth-service ──────────────────────────────────────────────
# บน Railway ใช้ DATABASE_URL แทน (Railway inject ให้อัตโนมัติ)
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_NAME=authdb
AUTH_DB_USER=admin
AUTH_DB_PASSWORD=secret

# ─── task-service ──────────────────────────────────────────────
TASK_DB_HOST=task-db
TASK_DB_PORT=5432
TASK_DB_NAME=taskdb
TASK_DB_USER=admin
TASK_DB_PASSWORD=secret

# ─── user-service ──────────────────────────────────────────────
USER_DB_HOST=user-db
USER_DB_PORT=5432
USER_DB_NAME=userdb
USER_DB_USER=admin
USER_DB_PASSWORD=secret
